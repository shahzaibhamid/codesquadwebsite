# ---------------------------------------------------------------------------
# CodeSquad — environment variables
# Copy this file to `.env.local` and fill in the values.
# The public site runs fully WITHOUT these (it uses static data in /data).
# Add these to make the /dashboard admin panel save to Supabase.
# ---------------------------------------------------------------------------

# Supabase — from your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: SERVER-ONLY, never exposed to the browser. Used by the
# dashboard to create/edit/delete posts. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# Password for the hidden /dashboard admin panel. Change this!
DASHBOARD_PASSWORD=codesquad-admin

# Public site URL (used for SEO / Open Graph absolute URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
